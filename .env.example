# FrankySheets Environment Configuration
# Copy this to .env and fill in your values

# === Google Sheets ===
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# === Blockchain (Ethereum Sepolia) ===
ETH_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# === Wallet ===
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
PRIVATE_KEY=your_private_key_for_contract_deployment

# === Smart Contract ===
FRANKYSHEETS_REPORT_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS
BALANCE_READER_ADDRESS=0xBALANCE_READER_ADDRESS
RISK_VAULT_ADDRESS=0xRISK_VAULT_ADDRESS
JUDGE_MODE=false

# === CRE Forwarder (Ethereum Sepolia) ===
CRE_FORWARDER_ADDRESS=0x15fC6ae953E024d975e77382eEeC56A9101f9F88

# === CRE Deployed Workflow Endpoints (production only) ===
# Set these after `cre workflow deploy` to bypass the local CLI simulator
# and POST trade commands directly to the deployed HTTP-trigger workflow.
# Leave blank during development (falls back to `cre workflow simulate --broadcast`).
CRE_AI_TRADE_ENDPOINT=
CRE_PRIVATE_TRADE_ENDPOINT=
CRE_READ_ORACLE_ENDPOINT=
CRE_EXECUTE_TRADE_ENDPOINT=
CRE_CROSS_CHAIN_PORTFOLIO_ENDPOINT=
CRE_TRADE_RECORD_ENDPOINT=

# === Webhook Security ===
# Static bearer token for CRE workflow callbacks (X-Webhook-Token header).
# CRE HTTPClient cannot compute HMAC, so workflows send this static value.
# Must match the `webhookToken` field in each workflow's config.staging.json.
# Generate with: openssl rand -hex 32
CRE_WEBHOOK_TOKEN=
# HMAC-SHA256 secret for verifying non-CRE webhook callbacks (optional).
# Generate with: openssl rand -hex 32
CRE_WEBHOOK_SECRET=

# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key

# === 1inch DEX (for Private Trade workflow) ===
ONEINCH_API_KEY=your_1inch_api_key
ZEROX_API_KEY=your_0x_api_key

# === Etherscan ===
ETHERSCAN_API_KEY=your_etherscan_key

# === Server ===
PORT=3000

# === CRE CLI Prerequisites ===
# Install CRE CLI: curl -sL https://smartcontractkit.github.io/cre-cli/install.sh | bash
# Agent must run on localhost:3000 (or update callbackWebhook in each workflow's config.staging.json)
CRE_SIMULATE_BROADCAST=false         # Set to "true" to broadcast real testnet txs when simulating
REQUIRE_CRE=false                    # Set to "true" to disable direct execution fallback (all trades must go through CRE)
DEFI_DEMO_MODE=false                 # Set to "true" to enable seeded DeFi positions for UI demo
