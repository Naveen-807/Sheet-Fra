# SheetFra Environment Configuration
# Copy this to .env and fill in your values

# === Google Sheets ===
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# === Blockchain (Polkadot Hub Testnet) ===
POLKADOT_HUB_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io

# === Wallet ===
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
DEPLOYER_PRIVATE_KEY=your_private_key_for_contract_deployment

# === Smart Contract ===
SHEETFRA_REGISTRY_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS
JUDGE_MODE=false

# === Webhook Security ===
WEBHOOK_TOKEN=
WEBHOOK_SECRET=

# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key

# === Server ===
PORT=3000

# === DeFi Demo Mode ===
DEFI_DEMO_MODE=false
