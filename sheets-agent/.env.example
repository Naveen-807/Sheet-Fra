# ═══════════════════════════════════════════════════════════
# FrankySheets Agent — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# Required variables are marked with [REQUIRED].
#
# QUICKSTART (minimum for demo):
#   1. ETH_SEPOLIA_RPC_URL + PRIVATE_KEY   → wallet + direct tx execution
#   2. GEMINI_API_KEY                       → AI chat (no CRE needed)
#   3. GOOGLE_SERVICE_ACCOUNT_KEY_PATH      → sheets integration
#   4. GOOGLE_SHEET_ID                      → target spreadsheet
#
# Everything else is optional for demo — enables deeper Nillion/WalletConnect features.

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development  # Set to "production" on deploy (blocks Nillion dev fallback)
CORS_ALLOWED_ORIGINS=  # Comma-separated origins. Blank = default Google Sheets origins.

# ── API Authentication ───────────────────────────────────────
# Required in production for all /api/* endpoints (X-API-Key header).
# Generate with: openssl rand -hex 32
FRANKY_API_KEY=

# ── Google Sheets ─── [REQUIRED] ────────────────────────────
GOOGLE_SHEET_ID=                              # Auto-discovered from Drive if blank
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json  # [REQUIRED] Service account JSON key
SHEET_OWNER_EMAIL=                            # Display in Settings tab (auto-detected from Drive API)

# ── Ethereum Sepolia ─── [REQUIRED] ─────────────────────────
ETH_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY  # [REQUIRED]
WALLET_ADDRESS=                               # Set by Connect Wallet or manually (for display)
# [REQUIRED for direct execution] Private key for transaction signing.
# When Nillion is not configured, this is used as the signing fallback.
# KEEP SECURE — never commit a real funded key.
PRIVATE_KEY=

# ── Smart Contracts (Sepolia) ───────────────────────────────
# Deploy with: cd contracts && forge script script/Deploy.s.sol --broadcast
FRANKYSHEETS_REPORT_ADDRESS=0x0e2158C3971535d7c6b6168685533860995a967C  # FrankySheetsReport
BALANCE_READER_ADDRESS=                                                  # BalanceReader helper
RISK_VAULT_ADDRESS=0x0B4b8AaE192378506c2e47B752b96eeb46C0BB1f           # RiskVault (on-chain risk rules)

# ── Gemini AI ─── [REQUIRED FOR AI CHAT] ────────────────────
# Direct Gemini 2.0 Flash API key — enables AI chat.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override Gemini model (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.0-flash-thinking-exp, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# ── Webhook Security ────────────────────────────────────────
# Static bearer token for webhook callbacks (X-Webhook-Token header).
# Generate with: openssl rand -hex 32
WEBHOOK_TOKEN=dev-webhook-token-change-in-production
# HMAC-SHA256 secret for webhook integrations (optional).
WEBHOOK_SECRET=
# Allow localhost webhook bypass in dev (set to "true")
ALLOW_LOOPBACK_WEBHOOK_BYPASS=true

# ── DeFi Demo Mode ──────────────────────────────────────────
# When DEFI_DEMO_MODE=true, seeded DeFi positions (yield farming, staking,
# liquidity) are enabled for UI demonstration. When false (default), DeFi
# position queries return empty arrays — real protocol integration required.
DEFI_DEMO_MODE=false

# ── Nillion Secret Vault ─── [PRIVACY TRACK] ────────────────
# See NILLION_SETUP.md for full setup instructions.
#
# 1. Get nilDB subscription + API key: https://subscription.nillion.com (nilPay)
# 2. Create schema at https://collection-explorer.nillion.com (label + value fields)
# 3. Fill in the three required vars below
#
# NILLION_API_KEY: 64-char hex from nilPay "Generate New Identity" OR JWT (eyJ...)
# NILLION_NODE_URL: nilDB endpoint (default: https://nildb.nillion.com)
# NILLION_SCHEMA_ID: Schema/collection ID from Collection Explorer
#
# Without Nillion: in-memory store (dev only) or PRIVATE_KEY fallback for signing.
NILLION_API_KEY=
NILLION_NODE_URL=https://nildb.nillion.com
NILLION_SCHEMA_ID=
# NILLION_NODE_AUD=                  # Optional; JWT audience. Default: testnet node DID
# NILLION_SECRET_ID=                 # Set by /api/wallet/init → store in Script Properties

# ── Privacy Mode ─────────────────────────────────────────────
# Privacy endpoints: GET /api/privacy/status
# When Nillion is configured: full privacy (wallet keys + data encryption)
# When PRIVATE_KEY only: partial privacy (signing works, no data encryption)
# Demonstration: curl http://localhost:3000/api/privacy/status

# ── Judge / Demo Mode ───────────────────────────────────────
# JUDGE_MODE=true disables all execution fallbacks.
# Leave false for hackathon demos.
JUDGE_MODE=false

# ═══════════════════════════════════════════════════════════
# TROUBLESHOOTING — "Why isn't AI chat working?"
# ═══════════════════════════════════════════════════════════
# 1. Agent must be running:  npm start  (or npm run dev)
# 2. GEMINI_API_KEY must be set above (get from https://aistudio.google.com/app/apikey)
# 3. Type your message in cell B2 of the "Chat with Wallet" tab
#    (older sheets created by Code.gs may use B3 — agent polls both)
# 4. Wait ~10-15 seconds for the agent's poll cycle to pick it up
# 5. Check terminal logs for errors if no response appears
# 6. Try /help as your first message to see all available commands

# ── WalletConnect v2 ────────────────────────────────────────
# Required for Connect to Dapp. Get at https://cloud.walletconnect.com
# Enables DApp connectivity from Google Sheets (Uniswap, 1inch, etc.)
WALLETCONNECT_PROJECT_ID=

# ── AI Chat ─────────────────────────────────────────────────
SKIP_AI_CHAT=false

# ── Etherscan ───────────────────────────────────────────────
ETHERSCAN_API_KEY=

