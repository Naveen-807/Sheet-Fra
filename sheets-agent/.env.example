# ═══════════════════════════════════════════════════════════
# SheetFra Agent — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# Required variables are marked with [REQUIRED].
#
# QUICKSTART (minimum for demo):
#   1. POLKADOT_HUB_RPC_URL             → chain connectivity (default provided)
#   2. GEMINI_API_KEY                    → AI chat
#   3. GOOGLE_SERVICE_ACCOUNT_KEY_PATH   → sheets integration
#   4. GOOGLE_SHEET_ID                   → target spreadsheet
#
# Everything else is optional for demo.

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development  # Set to "production" on deploy
CORS_ALLOWED_ORIGINS=  # Comma-separated origins. Blank = default Google Sheets origins.

# ── API Authentication ───────────────────────────────────────
# Required in production for all /api/* endpoints (X-API-Key header).
# Generate with: openssl rand -hex 32
SHEETFRA_API_KEY=

# ── Google Sheets ─── [REQUIRED] ────────────────────────────
GOOGLE_SHEET_ID=                              # Auto-discovered from Drive if blank
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json  # [REQUIRED] Service account JSON key
SHEET_OWNER_EMAIL=                            # Display in Settings tab (auto-detected from Drive API)

# ── Polkadot Hub Testnet ─── [REQUIRED] ─────────────────────
POLKADOT_HUB_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io  # [REQUIRED]
WALLET_ADDRESS=                               # Set by Connect Wallet or manually (for display)
# [REQUIRED for direct execution] Private key for transaction signing.
# KEEP SECURE — never commit a real funded key.
DEPLOYER_PRIVATE_KEY=

# ── Smart Contracts (Polkadot Hub) ────────────────────────────
# Deploy with: cd contracts && npx hardhat run scripts/deploy.ts --network polkadotHub
SHEETFRA_REGISTRY_ADDRESS=                    # SheetFraRegistry contract

# ── Polkadot Hub Token Addresses ──────────────────────────────
# Fill in after deploying or discovering token contracts on Polkadot Hub testnet
POLKADOT_HUB_USDT=                            # USDT on Polkadot Hub
POLKADOT_HUB_WETH=                            # WETH (bridged via Snowbridge)

# ── Gemini AI ─── [REQUIRED FOR AI CHAT] ────────────────────
# Direct Gemini 2.0 Flash API key — enables AI chat.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Webhook Security ────────────────────────────────────────
# Static bearer token for webhook callbacks (X-Webhook-Token header).
# Generate with: openssl rand -hex 32
WEBHOOK_TOKEN=dev-webhook-token-change-in-production
# HMAC-SHA256 secret for webhook integrations (optional).
WEBHOOK_SECRET=
# Allow localhost webhook bypass in dev (set to "true")
ALLOW_LOOPBACK_WEBHOOK_BYPASS=true

# ── DeFi Demo Mode ──────────────────────────────────────────
# When DEFI_DEMO_MODE=true, seeded DeFi positions (yield farming, staking,
# liquidity) are enabled for UI demonstration.
DEFI_DEMO_MODE=false

# ── Judge / Demo Mode ───────────────────────────────────────
# JUDGE_MODE is deprecated — all data is now real from on-chain RPC + CoinGecko.
# Setting JUDGE_MODE=true no longer seeds fake data.
JUDGE_MODE=false

# ═══════════════════════════════════════════════════════════
# TROUBLESHOOTING — "Why isn't AI chat working?"
# ═══════════════════════════════════════════════════════════
# 1. Agent must be running:  npm start  (or npm run dev)
# 2. GEMINI_API_KEY must be set above (get from https://aistudio.google.com/app/apikey)
# 3. Type your message in cell B2 of the "Chat with Wallet" tab
#    (older sheets created by Code.gs may use B3 — agent polls both)
# 4. Wait ~10-15 seconds for the agent's poll cycle to pick it up
# 5. Check terminal logs for errors if no response appears
# 6. Try /help as your first message to see all available commands

# ── WalletConnect v2 ────────────────────────────────────────
# Required for Connect to Dapp. Get at https://cloud.walletconnect.com
# Enables DApp connectivity from Google Sheets (Hydration, etc.)
WALLETCONNECT_PROJECT_ID=

# ── AI Chat ─────────────────────────────────────────────────
SKIP_AI_CHAT=false
